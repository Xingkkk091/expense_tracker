<?xml version="1.0" encoding="utf-8"?>
<!-- Android 12+：分雲端備份與裝置間轉移 -->
<data-extraction-rules>
    <cloud-backup>
        <include domain="database" path="expense_tracker.db" />
        <include domain="sharedpref" path="." />
        <include domain="file" path="receipts/" />
        <include domain="file" path="auto_backups/" />
    </cloud-backup>
    <device-transfer>
        <include domain="database" path="expense_tracker.db" />
        <include domain="sharedpref" path="." />
        <include domain="file" path="receipts/" />
        <include domain="file" path="auto_backups/" />
    </device-transfer>
</data-extraction-rules>
